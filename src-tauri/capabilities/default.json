{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default desktop capability for Pi Agent",
  "local": true,
  "remote": {
    "urls": ["http://localhost:*"]
  },
  "windows": ["*"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    "shell:default",
    "updater:default",
    "process:default",
    "core:window:allow-start-dragging",
    "default"
  ]
}
