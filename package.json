{
  "name": "picot",
  "version": "0.3.5",
  "description": "Local Codex-style desktop GUI for the Pi coding agent",
  "keywords": [
    "picot",
    "pi",
    "coding-agent",
    "desktop",
    "multi-agent",
    "tauri"
  ],
  "author": "deflating",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shixin-guo/picot.git"
  },
  "scripts": {
    "tauri": "tauri",
    "dev": "bun run fetch:pi && bun run build:frontend && PATH=\"$HOME/.cargo/bin:$PATH\" tauri dev",
    "fetch:pi": "bun run scripts/fetch-pi-binary.js",
    "smoke:pi-rpc": "bun run scripts/smoke-pi-rpc.js",
    "build:extensions": "bun run scripts/build-extensions.js",
    "build:frontend": "node scripts/build-frontend.js",
    "build:frontend:watch": "node scripts/build-frontend.js --watch",
    "build": "PATH=\"$HOME/.cargo/bin:$PATH\" tauri build",
    "prebuild": "bun run fetch:pi && bun run build:extensions && bun run build:frontend",
    "release": "bash scripts/release.sh",
    "release:mac:dmg": "bash scripts/release-macos-dmg.sh",
    "test": "vitest run && bun run scripts/check-tauri-permissions.js",
    "prepare": "husky",
    "test:watch": "vitest",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write . --unsafe",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "check": "biome check . && bun run check:design",
    "check:fix": "biome check --write . --unsafe --formatter-enabled=false --linter-enabled=false && bun run check:design:fix",
    "check:design": "bun scripts/check-design-css.mjs",
    "check:design:fix": "bun scripts/check-design-css.mjs --fix",
    "check:permissions": "bun run scripts/check-tauri-permissions.js",
    "check:rust": "bash scripts/check-rust.sh"
  },
  "dependencies": {
    "@codemirror/commands": "6.10.1",
    "@codemirror/lang-css": "6.3.1",
    "@codemirror/lang-html": "6.4.11",
    "@codemirror/lang-javascript": "6.2.4",
    "@codemirror/lang-json": "6.0.2",
    "@codemirror/lang-markdown": "6.5.0",
    "@codemirror/lang-python": "6.2.1",
    "@codemirror/lang-yaml": "6.1.2",
    "@codemirror/language": "6.12.2",
    "@codemirror/legacy-modes": "6.5.2",
    "@codemirror/search": "6.6.0",
    "@codemirror/state": "6.5.4",
    "@codemirror/view": "6.39.13",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "pdfjs-dist": "^4.10.38",
    "qrcode": "^1.5.0",
    "remend": "^1.3.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@tauri-apps/cli": "^2.11.2",
    "esbuild": "^0.28.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "vitest": "^3.2.4"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
