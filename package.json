{
  "name": "pi-studio",
  "version": "0.1.7",
  "description": "Local Codex-style GUI for the Pi coding agent — desktop app and browser extension",
  "keywords": [
    "pi",
    "pi-package",
    "coding-agent",
    "web-ui",
    "desktop",
    "multi-agent",
    "tauri"
  ],
  "author": "deflating",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/deflating/pi-studio.git"
  },
  "pi": {
    "extensions": [
      "./extensions/mirror-server.ts"
    ],
    "image": "https://raw.githubusercontent.com/deflating/pi-studio/main/docs/images/dark.png"
  },
  "scripts": {
    "tauri": "tauri",
    "dev:web": "live-server public --host=127.0.0.1 --port=1420 --no-browser",
    "dev": "PATH=\"$HOME/.cargo/bin:$PATH\" tauri dev",
    "build": "PATH=\"$HOME/.cargo/bin:$PATH\" tauri build",
    "release": "bash scripts/release.sh",
    "release:mac:dmg": "bash scripts/release-macos-dmg.sh",
    "test": "vitest run && node scripts/check-tauri-permissions.js",
    "test:watch": "vitest",
    "check:permissions": "node scripts/check-tauri-permissions.js",
    "check:rust": "bash scripts/check-rust.sh"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "qrcode": "^1.5.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "jsdom": "^26.1.0",
    "live-server": "^1.2.2",
    "vitest": "^3.2.4"
  }
}
