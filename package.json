{
  "name": "pi-studio",
  "version": "0.1.22-6",
  "description": "Local Codex-style desktop GUI for the Pi coding agent",
  "keywords": [
    "pi",
    "coding-agent",
    "desktop",
    "multi-agent",
    "tauri"
  ],
  "author": "deflating",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/deflating/pi-studio.git"
  },
  "scripts": {
    "tauri": "tauri",
    "dev": "bun run fetch:pi && PATH=\"$HOME/.cargo/bin:$PATH\" tauri dev",
    "fetch:pi": "bun run scripts/fetch-pi-binary.js",
    "build:extensions": "bun run scripts/build-extensions.js",
    "build": "PATH=\"$HOME/.cargo/bin:$PATH\" tauri build",
    "prebuild": "bun run fetch:pi && bun run build:extensions",
    "release": "bash scripts/release.sh",
    "release:mac:dmg": "bash scripts/release-macos-dmg.sh",
    "test": "vitest run && bun run scripts/check-tauri-permissions.js",
    "test:watch": "vitest",
    "check:permissions": "bun run scripts/check-tauri-permissions.js",
    "check:rust": "bash scripts/check-rust.sh"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "qrcode": "^1.5.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "esbuild": "^0.28.0",
    "jsdom": "^26.1.0",
    "vitest": "^3.2.4"
  }
}
